{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["overlay", "settings"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:path:default",
    "core:tray:default",
    "core:menu:default",
    "core:window:allow-start-dragging",
    "core:window:allow-start-resize-dragging",
    "updater:default",
    "process:default"
  ]
}
